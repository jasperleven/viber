[Unit]
Description=Viber Bot - AmoCRM Webhook Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/viber_bot
ExecStart=/opt/viber_bot/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=10
StandardOutput=append:/var/log/viber_bot.log
StandardError=append:/var/log/viber_bot.log

[Install]
WantedBy=multi-user.target
